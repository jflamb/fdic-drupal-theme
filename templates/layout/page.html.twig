{#
/**
 * @file
 * Theme override for the main page structure.
 */
#}
{% set page_classes = [
  'fdic-page',
  is_front ? 'fdic-page--front',
] %}

<div{{ create_attribute({'class': page_classes}) }}>
  {{ page.header }}

  {% if is_front %}
  {% endif %}

  {% if page.breadcrumb %}
    <div class="fdic-region fdic-breadcrumb-region">
      {{ page.breadcrumb }}
    </div>
  {% endif %}

  {% if page.highlighted %}
    <div class="fdic-region fdic-highlighted" role="region" aria-label="{{ 'Highlighted content'|t }}">
      {{ page.highlighted }}
    </div>
  {% endif %}

  {% set layout_classes = [
    'fdic-container',
    'fdic-main-layout',
    page.sidebar_first ? 'has-sidebar-first',
    page.sidebar_second ? 'has-sidebar-second',
  ] %}

  <main id="main-content" class="fdic-main" role="main" tabindex="-1">
    <div{{ create_attribute({'class': layout_classes}) }}>
      {% if page.sidebar_first %}
        <aside class="fdic-sidebar fdic-sidebar-first" role="complementary" aria-label="{{ 'First sidebar'|t }}">
          {{ page.sidebar_first }}
        </aside>
      {% endif %}

      <div class="fdic-content">
        {{ page.content }}
      </div>

      {% if page.sidebar_second %}
        <aside class="fdic-sidebar fdic-sidebar-second" role="complementary" aria-label="{{ 'Second sidebar'|t }}">
          {{ page.sidebar_second }}
        </aside>
      {% endif %}
    </div>
  </main>

  {{ page.footer }}

  <fd-page-feedback class="fdic-page-feedback" survey-href="{{ path('<front>') }}"></fd-page-feedback>

  {% set footer_source = {
    utilityLinks: [
      {
        label: 'Accessibility'|t,
        href: path('<front>'),
      },
    ],
    socialLinks: [
      {
        label: 'FDIC on Facebook'|t,
        href: 'https://www.facebook.com/fdicgov/',
        icon: 'facebook',
      },
      {
        label: 'FDIC on X'|t,
        href: 'https://x.com/fdicgov',
        icon: 'x',
      },
      {
        label: 'FDIC on Instagram'|t,
        href: 'https://www.instagram.com/fdicgov/',
        icon: 'instagram',
      },
      {
        label: 'FDIC on YouTube'|t,
        href: 'https://www.youtube.com/user/FDICchannel',
        icon: 'youtube',
      },
      {
        label: 'FDIC on LinkedIn'|t,
        href: 'https://www.linkedin.com/company/fdic/',
        icon: 'linkedin',
      },
    ],
  } %}
  <fd-global-footer
    id="about"
    data-fdic-global-footer
    agency-name="{{ 'Federal Deposit Insurance Corp.'|t }}"
    agency-href="{{ path('<front>') }}"
    updated-text="{{ 'Updated August 7, 2024'|t }}">
    <script type="application/json" data-fdic-global-footer-source>{{ footer_source|json_encode(constant('JSON_HEX_TAG'))|raw }}</script>
  </fd-global-footer>
</div>
