{#
/**
 * @file
 * Theme override for the header region.
 */
#}
{{ attach_library('fdic/global-header') }}

{% set header_source = {
  items: [
    {
      title: 'News & Events'|t,
      url: path('<front>') ~ '#news',
      current: is_front|default(false),
    },
    {
      title: 'Learning'|t,
      url: path('<front>') ~ '#career',
    },
    {
      title: 'Knowledge Base'|t,
      url: path('<front>') ~ '#knowledge',
    },
    {
      title: 'Benefits'|t,
      url: path('<front>') ~ '#benefits',
    },
    {
      title: 'Support'|t,
      url: path('<front>') ~ '#services',
    },
    {
      title: 'About'|t,
      url: path('<front>') ~ '#about',
    },
  ],
  search: {
    action: path('<front>'),
    paramName: 'keys',
    label: 'Search FDICnet'|t,
    placeholder: 'Search FDICnet'|t,
    searchAllLabel: 'Search all FDICnet'|t,
  }
} %}

<fd-global-header data-fdic-global-header>
  <a slot="brand" class="fdic-global-header__brand-link" href="{{ path('<front>') }}" aria-label="{{ 'FDICnet home'|t }}">
    <img
      class="fdic-global-header__brand-image"
      src="/{{ directory }}/assets/fdicnet-wordmark.svg"
      alt="{{ 'FDICnet'|t }}"
      width="140"
      height="35">
  </a>
  <fd-button slot="utility" variant="subtle-inverted" aria-label="{{ 'Profile'|t }}" type="button">
    <fd-icon slot="icon-start" name="user-circle" aria-hidden="true" style="--fd-icon-size:1.75rem;"></fd-icon>
  </fd-button>
  <script type="application/json" data-fdic-global-header-source>{{ header_source|json_encode(constant('JSON_HEX_TAG'))|raw }}</script>
</fd-global-header>
