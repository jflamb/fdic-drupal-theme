{#
/**
 * @file
 * Theme override for input elements.
 *
 * fd-input is a form-associated custom element that participates in form
 * submission via ElementInternals. Pass Drupal input attributes directly
 * to the fd-input host. Non-upgradeable types remain as native elements.
 *
 * A native fallback remains usable until the custom element is defined.
 */
#}
{% set type = fdic_input_type|default('text') %}
{% if type in ['hidden', 'submit', 'button', 'image', 'reset', 'checkbox', 'radio'] %}
  <input{{ attributes }} />{{ children }}
{% else %}
  {% set control_id = fdic_input_id|default('') %}
  <fd-input{{ attributes.addClass('fdic-form-control') }}></fd-input>
  <span class="fdic-control-fallback" data-fdic-control-fallback-for="{{ control_id }}">
    {% set fallback_attributes = attributes.removeClass('fdic-form-control') %}
    {% if control_id %}
      {% set fallback_attributes = fallback_attributes.setAttribute('id', control_id ~ '--native') %}
    {% endif %}
    <input{{ fallback_attributes }} />
  </span>
  {{ children }}
{% endif %}
